# Panopto Downloader — Environment Variables
#
# Copy this file to .env and fill in your credentials.
# The default profile uses PANOPTO_* variables.
# For additional profiles, pass --server / --client-id flags at login time.
#
# Usage:
#   panopto-downloader auth login                         (default profile)
#   panopto-downloader --profile eecs auth login \
#     --server mit.hosted.panopto.com \
#     --client-id 4c2a19ab-519a-4939-8335-b430000dd393 \ 
#     --client-secret "aW1maQKQy8KUA5PIMxNjrj59bS7WYL/SW0mjqUNNrG0="
#
# Tokens are stored per-profile:
#   ~/.config/panopto-downloader/tokens-default.json
#   ~/.config/panopto-downloader/tokens-eecs.json
#   etc.

# ── MIT Sloan (default profile) ─────────────────────────────────────────────
PANOPTO_SERVER=mitsloan.hosted.panopto.com
PANOPTO_CLIENT_ID=your-sloan-client-id-here
PANOPTO_CLIENT_SECRET=your-sloan-client-secret-here

# ── MIT EECS (--profile eecs) ────────────────────────────────────────────────
# Server:        mit.hosted.panopto.com
# Client ID:     4c2a19ab-519a-4939-8335-b430000dd393
# Login command (run once, then tokens persist):
#   panopto-downloader --profile eecs auth login \
#     --server mit.hosted.panopto.com \
#     --client-id 4c2a19ab-519a-4939-8335-b430000dd393 \
#     --client-secret "aW1maQKQy8KUA5PIMxNjrj59bS7WYL/SW0mjqUNNrG0="
